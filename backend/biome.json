{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "noUnusedVariables": "error"
      },
      "style": {
      "noNonNullAssertion": "off",
      "useImportType": "off"
    }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "trailingCommas": "all" },
    "parser": { "unsafeParameterDecoratorsEnabled": true }
  },
  "files": {
    "includes": [
      "**",
      "!node_modules/**",
      "!dist/**",
      "!backend/node_modules/**",
      "!backend/dist/**",
      "!.git/**"
    ]
  }
}
