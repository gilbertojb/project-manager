generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id
  name        String
  start_date  DateTime
  end_date    DateTime
  budget      Float
  description String
  status         String
  risk           String
  ai_analysis    Json?
  ai_analyzed_at DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("projects")
}
