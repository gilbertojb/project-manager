generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id
  name        String
  start_date  DateTime
  end_date    DateTime
  budget      Float
  description String
  status      String
  risk        String
  created_at  DateTime
  updated_at  DateTime

  @@map("projects")
}
